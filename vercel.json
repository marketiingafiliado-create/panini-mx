{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/checkout", "dest": "/checkout.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
